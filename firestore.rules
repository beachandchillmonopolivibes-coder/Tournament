rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regole globali: gli Admin autenticati (con custom claim 'admin') possono fare tutto
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Simulazione di API Pubblica Serverless per i Dati Live
    // Nota: Le Firestore Security Rules standard non leggono "request.origin" né i query parameters (come ?apiKey=...).
    // Per ottenere il comportamento richiesto in una vera applicazione serverless Firestore:
    // 1. Dominio Autorizzato: Si abilita "Firebase App Check" con reCAPTCHA Enterprise o simili. Questo blocca le richieste non provenienti dal dominio.
    // 2. Chiave API: Si utilizza la chiave come ID del documento per la lettura diretta (es. /Public_Live_Data/API_KEY_123)
    //    oppure si imposta una regola che valida i dati.

    match /Public_Live_Data/{documentId} {
      // In assenza di backend Node.js, l'approccio migliore per Firestore puro
      // è permettere la lettura in sola lettura (blindando il dominio con Firebase App Check).
      // Se si usa l'API Key come ID del documento:
      allow read: if true;
    }
  }
}
